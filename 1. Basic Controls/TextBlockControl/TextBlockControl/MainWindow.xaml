<Window x:Class="TextBlockControl.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TextBlockControl"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0">This is First TextBlock</TextBlock>
        <TextBlock Grid.Row="1" 
                   Margin="10,10,10,10">
            This is Second TextBlock
        </TextBlock>
        <TextBlock Grid.Row="2" 
                   Margin="10,10,10,10">
            This a TextBlock Control and it come with a very long text
        </TextBlock>
        <TextBlock Grid.Row="3" 
                   Margin="10,10,10,10">
            This is a TextBlock Control and <LineBreak/> it come with a very long text
        </TextBlock>
        <TextBlock Grid.Row="4" 
                   Margin="10,10,10,10" 
                   TextTrimming="CharacterEllipsis" 
                   Foreground="Red">
            This is a TextBlock Control and it come with a very long text
        </TextBlock>
        <TextBlock Grid.Row="5" 
                   Margin="10,10,10,10" 
                   TextTrimming="WordEllipsis" 
                   Foreground="Blue">
            This is a TextBlock Control and it come with a very long text
        </TextBlock>
        <TextBlock Grid.Row="6" 
                   Margin="10,10,10,10" 
                   TextWrapping="Wrap" 
                   Foreground="Green">
            This is a TextBlock Control and it come with a very long text
        </TextBlock>
        <TextBlock Grid.Row="7" 
                   Margin="10,10,10,10">
            Textblock with <Bold>Bold </Bold>, <Italic> Italic</Italic> and <Underline>Underline</Underline> text
        </TextBlock>
        <TextBlock Grid.Row="8"
                   Margin="10,10,10,10">
            This text has a <Hyperlink RequestNavigate="HyperLink_RequestNavigate" NavigateUri="https://www.google.com/"> Link </Hyperlink> in it.
        </TextBlock>
        <TextBlock Grid.Row="9"
                   Margin="10,10,10,10">
            This <Span FontWeight="Bold"> is </Span> a <Span Background="Silver" Foreground="Red">TextBlock</Span> with <Span TextDecorations="Underline">Several</Span> <Span FontStyle="Italic"> Span</Span> elements, <Span Foreground="Blue"> using a <Bold>Variety</Bold> of <Italic> Styles</Italic></Span>
        </TextBlock>
    </Grid>
</Window>
